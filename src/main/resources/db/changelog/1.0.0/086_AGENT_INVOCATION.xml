<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001_AGENT_INVOCATION_CREATE" author="${author}">
        <comment>Audit trail for v2 LLM agent invocations (tokens, cost, tools, status)</comment>

        <createTable tableName="agent_invocation">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="tenant_id" type="BIGINT" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>

            <column name="user_id" type="BIGINT">
                <constraints nullable="true"/>
            </column>

            <column name="conversation_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="agent_name" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="model" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>

            <column name="user_message" type="TEXT">
                <constraints nullable="false"/>
            </column>

            <column name="final_response" type="TEXT"/>

            <column name="tools_used" type="TEXT"/>

            <column name="input_tokens" type="INT" defaultValueNumeric="0"/>
            <column name="output_tokens" type="INT" defaultValueNumeric="0"/>
            <column name="cache_read_tokens" type="INT" defaultValueNumeric="0"/>
            <column name="cache_creation_tokens" type="INT" defaultValueNumeric="0"/>

            <column name="cost_micro_usd" type="BIGINT" defaultValueNumeric="0"/>

            <column name="duration_ms" type="INT" defaultValueNumeric="0"/>

            <column name="status" type="VARCHAR(24)">
                <constraints nullable="false"/>
            </column>

            <column name="error_message" type="TEXT"/>

            <column name="created_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="agent_invocation" indexName="idx_agent_invocation_conversation">
            <column name="conversation_id"/>
        </createIndex>

        <createIndex tableName="agent_invocation" indexName="idx_agent_invocation_user">
            <column name="user_id"/>
        </createIndex>

        <createIndex tableName="agent_invocation" indexName="idx_agent_invocation_created_at">
            <column name="created_at" descending="true"/>
        </createIndex>

        <createIndex tableName="agent_invocation" indexName="idx_agent_invocation_agent_name">
            <column name="agent_name"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
