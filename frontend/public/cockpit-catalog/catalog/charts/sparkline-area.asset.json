{
  "$schema": "../_schema/asset.v1.json",
  "id": "chart:sparkline-area",
  "category": "chart",
  "title": "Sparkline aire + crosshair",
  "description": "Sparkline SVG : grille pointillée + path d'aire dégradé + ligne stroke + scatter points + crosshair (lignes pointillées) sur le dernier pic.",
  "viewBox": "0 0 300 100",
  "params": {
    "title": { "type": "string", "default": "Loss Function (MSE)" },
    "value": { "type": "string", "default": "0.0142", "description": "Valeur KPI affichée au-dessus" },
    "points": {
      "type": "array",
      "items": { "x": "number", "y": "number" },
      "default": [
        {"x":0,"y":90},{"x":20,"y":75},{"x":40,"y":80},{"x":60,"y":50},{"x":80,"y":65},
        {"x":100,"y":40},{"x":120,"y":45},{"x":140,"y":25},{"x":160,"y":35},{"x":180,"y":15},
        {"x":200,"y":20},{"x":220,"y":10},{"x":240,"y":15},{"x":260,"y":5},{"x":280,"y":8},{"x":300,"y":2}
      ],
      "description": "Points (x dans 0..300, y dans 0..100)"
    },
    "scatter": {
      "type": "array",
      "items": { "x": "number", "y": "number", "filled": "boolean" },
      "default": [
        {"x":60,"y":50,"filled":false},
        {"x":140,"y":25,"filled":false},
        {"x":220,"y":10,"filled":false},
        {"x":300,"y":2,"filled":true}
      ]
    },
    "crosshair": {
      "type": "object",
      "default": { "x": 220, "y": 10 },
      "description": "Position du crosshair pointillé"
    }
  },
  "tokens": ["--ct-text-strong", "--ct-text-muted", "--ct-surface-2", "--ct-bg-deep"],
  "animations": [],
  "kind": "html",
  "render": {
    "html": "<div class=\"spark-wrap\">\n  <div class=\"spark-head\">\n    <span class=\"spark-title\">{{title}}</span>\n    <span class=\"spark-value\">{{value}}</span>\n  </div>\n  <svg class=\"spark-svg\" viewBox=\"-6 -6 312 122\" preserveAspectRatio=\"none\">\n    <defs>\n      <linearGradient id=\"areaGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n        <stop offset=\"0%\" stop-color=\"var(--ct-text-strong)\" stop-opacity=\"0.18\" />\n        <stop offset=\"100%\" stop-color=\"var(--ct-text-strong)\" stop-opacity=\"0\" />\n      </linearGradient>\n      <pattern id=\"grid\" width=\"30\" height=\"25\" patternUnits=\"userSpaceOnUse\">\n        <path d=\"M 30 0 L 0 0 0 25\" fill=\"none\" stroke=\"var(--ct-border-soft)\" stroke-width=\"1\" vector-effect=\"non-scaling-stroke\"/>\n      </pattern>\n    </defs>\n    <rect x=\"0\" y=\"0\" width=\"300\" height=\"110\" fill=\"url(#grid)\" />\n    <path d=\"{{areaPath points}}\" fill=\"url(#areaGrad)\" transform=\"translate(0,5)\"></path>\n    <path d=\"{{linePath points}}\" fill=\"none\" stroke=\"var(--ct-text-strong)\" stroke-width=\"1.5\" stroke-linejoin=\"round\" vector-effect=\"non-scaling-stroke\" transform=\"translate(0,5)\"></path>\n    {{#each scatter as |s|}}\n      <circle cx=\"{{s.x}}\" cy=\"{{s.y + 5}}\" r=\"3\" fill=\"{{#if s.filled}}var(--ct-text-strong){{else}}var(--ct-bg-deep){{/if}}\" stroke=\"var(--ct-text-strong)\" stroke-width=\"1.5\" vector-effect=\"non-scaling-stroke\"/>\n    {{/each}}\n    <line x1=\"{{crosshair.x}}\" y1=\"0\" x2=\"{{crosshair.x}}\" y2=\"110\" stroke=\"var(--ct-text-muted)\" stroke-width=\"1\" stroke-dasharray=\"2 3\" vector-effect=\"non-scaling-stroke\"></line>\n    <line x1=\"0\" y1=\"{{crosshair.y + 5}}\" x2=\"300\" y2=\"{{crosshair.y + 5}}\" stroke=\"var(--ct-text-muted)\" stroke-width=\"1\" stroke-dasharray=\"2 3\" vector-effect=\"non-scaling-stroke\"></line>\n  </svg>\n</div>",
    "css": ".spark-wrap { display: flex; flex-direction: column; gap: 8px; height: 100%; width: 100%; }\n.spark-head { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; }\n.spark-title { font-size: 11px; font-weight: 600; color: var(--ct-text-muted); text-transform: uppercase; letter-spacing: 0.04em; }\n.spark-value { font-size: 22px; font-weight: 700; color: var(--ct-text-strong); letter-spacing: -0.02em; font-variant-numeric: tabular-nums; }\n.spark-svg { flex: 1; width: 100%; min-height: 0; display: block; overflow: visible; }"
  }
}
