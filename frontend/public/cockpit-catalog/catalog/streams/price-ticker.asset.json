{
  "$schema": "https://hearst.app/schemas/asset.v1.json",
  "id": "stream:price-ticker",
  "kind": "stream",
  "category": "stream",
  "title": "Price Ticker",
  "description": "Ticker style crypto : symbole, prix courant, variation ±% avec flèche directionnelle et animation flash sur changement de valeur.",
  "viewBox": "0 0 320 64",
  "params": {
    "source": {
      "type": "string",
      "description": "URL de la source : ws://, sse://, ou mock:price",
      "default": "mock:price"
    },
    "symbol": {
      "type": "string",
      "description": "Paire de trading affichée à gauche",
      "default": "BTC/USD"
    },
    "precision": {
      "type": "number",
      "description": "Nombre de décimales sur le prix",
      "default": 2
    }
  },
  "render": {
    "html": "<div class=\"ct-ticker\" data-source=\"{{source}}\" data-symbol=\"{{symbol}}\" data-precision=\"{{precision}}\">\n  <span class=\"ct-ticker-symbol\">{{symbol}}</span>\n  <span class=\"ct-ticker-price\">—</span>\n  <span class=\"ct-ticker-change ct-ticker-neutral\">—</span>\n</div>",
    "css": ".ct-ticker{display:flex;align-items:center;justify-content:space-between;padding:14px 20px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.10);border-radius:12px;backdrop-filter:blur(24px) saturate(150%);box-shadow:inset 0 1px 0 rgba(255,255,255,0.18),0 20px 60px -24px rgba(0,0,0,0.65);gap:16px;min-width:280px;font-family:'Satoshi Variable',Inter,system-ui,sans-serif;}.ct-ticker-symbol{font-size:13px;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:rgba(245,245,245,0.48);flex-shrink:0;font-family:'JetBrains Mono',ui-monospace,monospace;}.ct-ticker-price{font-size:28px;font-weight:800;color:#ffffff;letter-spacing:-0.5px;transition:color 180ms cubic-bezier(0.2,0.7,0.2,1);flex:1;text-align:center;}.ct-ticker-price.ct-flash-up{animation:ct-flash-up 300ms ease-out;}.ct-ticker-price.ct-flash-down{animation:ct-flash-down 300ms ease-out;}.ct-ticker-change{font-size:13px;font-weight:700;min-width:80px;text-align:right;transition:color 180ms cubic-bezier(0.2,0.7,0.2,1);}.ct-ticker-up{color:#22c55e;}.ct-ticker-down{color:#e11d48;}.ct-ticker-neutral{color:rgba(245,245,245,0.48);}@keyframes ct-flash-up{0%{color:#22c55e;text-shadow:0 0 12px rgba(34,197,94,0.6);}100%{color:#ffffff;text-shadow:none;}}@keyframes ct-flash-down{0%{color:#e11d48;text-shadow:0 0 12px rgba(225,29,72,0.6);}100%{color:#ffffff;text-shadow:none;}}"
  },
  "tokens": [
    "--ct-surface-1",
    "--ct-border",
    "--ct-text-strong",
    "--ct-text-muted",
    "--ct-accent-strong",
    "--ct-shadow-depth"
  ],
  "animations": ["ct-flash-up", "ct-flash-down"]
}
