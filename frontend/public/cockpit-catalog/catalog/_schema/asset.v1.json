{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hearst.app/schemas/asset.v1.json",
  "title": "Cockpit Asset v1",
  "description": "Schéma d'un asset graphique du catalogue Cockpit — un agent doit pouvoir rendre l'asset à partir de ce seul fichier.",
  "type": "object",
  "required": ["id", "kind", "category", "title", "render"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(chart|kpi|viz|stream):[a-z0-9-]+$",
      "description": "Identifiant unique de la forme <category>:<slug>"
    },
    "kind": {
      "enum": ["svg", "canvas", "html", "vega", "stream"],
      "description": "Technologie de rendu primaire"
    },
    "category": {
      "enum": ["chart", "kpi", "viz", "stream"],
      "description": "Famille fonctionnelle"
    },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "viewBox": {
      "type": "string",
      "description": "viewBox SVG si applicable (ex: '0 0 100 100')"
    },
    "params": {
      "type": "object",
      "description": "Paramètres acceptés par le template, chaque clé documente type/default/description"
    },
    "render": {
      "type": "object",
      "description": "Implémentations possibles selon kind",
      "properties": {
        "svg":    { "type": "string", "description": "SVG template avec placeholders {{slot}}" },
        "html":   { "type": "string", "description": "Template HTML avec placeholders {{slot}}" },
        "css":    { "type": "string", "description": "CSS associé (classes utilisées par html/svg)" },
        "canvas": {
          "type": "object",
          "description": "Spec canvas — init + animate en JS string",
          "properties": {
            "width":   { "type": "number" },
            "height":  { "type": "number" },
            "init":    { "type": "string", "description": "Fonction JS string (canvas, params) => animate" }
          }
        },
        "vega":   { "type": "object", "description": "Vega-Lite spec" }
      }
    },
    "tokens": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Liste des tokens design utilisés (--ct-*)"
    },
    "animations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Noms des @keyframes consommés (spin, scan, blink, etc.)"
    }
  }
}
