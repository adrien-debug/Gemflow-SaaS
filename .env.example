# ============================================
# Backend env vars - Gemflow SaaS
# Copy to .env.local and fill in real values.
# Never commit .env.local.
# ============================================

# --- Database (Supabase PostgreSQL) ---
APP_DATABASE_URL=jdbc:postgresql://aws-0-eu-central-1.pooler.supabase.com:6543/postgres
APP_DATABASE_USERNAME=postgres.<your-project-ref>
APP_DATABASE_PASSWORD=<your-supabase-db-password>

# --- Supabase Auth ---
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_JWT_AUDIENCE=authenticated

# --- App ---
APP_NAME=Gemsflow
APP_ACTIVE_PROFILE=prod
APP_ORGANIZATION_NAME=Gemsflow
SERVER_PORT=8000
APP_SHOW_SQL=false
APP_SWAGGER_ENABLE=false

# --- CORS / Frontend ---
APP_CORS_ALLOWED_ORIGINS=https://gemflow-saas.vercel.app,https://*.vercel.app,http://localhost:7101
APP_FRONTEND_URL=https://gemflow-saas.vercel.app
APP_FRONTEND_NEW_PASSWORD_PATH=/new-password
APP_FRONTEND_RESTORE_PASSWORD_PATH=/restore-password
APP_FRONTEND_TIMEZONE=America/New_York

# --- Email (SMTP) ---
APP_EMAIL_ENABLE=false
APP_EMAIL_HOST=
APP_EMAIL_PORT=587
APP_EMAIL_USERNAME=
APP_EMAIL_PASSWORD=
APP_EMAIL_PROTOCOL=smtp
APP_EMAIL_SENDER=noreply@gemsflow.com

# --- File storage ---
APP_FILE_SOURCE=LOCAL
APP_S3_REGION=
APP_S3_ACCESS_KEY=
APP_S3_SECRET_KEY=
APP_S3_BUCKET=

# --- QuickBooks (optional) ---
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
QUICKBOOKS_REDIRECT_URI=http://localhost:7001/api/v1/integrations/quickbooks/callback
QUICKBOOKS_ENV=sandbox

# --- Stripe (optional) ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
